generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Era {
  id           Int         @id @default(autoincrement())
  name         String      @unique
  slug         String      @unique
  duration     String
  climate      String
  description  String      @db.Text
  bannerImage  String?

  dinosaurs    Dinosaur[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Dinosaur {
  id              Int      @id @default(autoincrement())

  eraId           Int
  era             Era      @relation(fields: [eraId], references: [id])

  name            String
  scientificName  String

  diet            String

  height          String
  length          String
  weight          String
  speed           String

  habitat         String

  image           String

  model3d              String?
  model3dCreditName    String?
  model3dCreditUrl     String?
  model3dLicense       String?

  description     String   @db.Text

  isFeatured      Boolean  @default(false)

  fossilFinds     FossilFind[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")

  quizAttempts QuizAttempt[]
  fossilFinds  FossilFind[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FossilFind {
  id         Int      @id @default(autoincrement())

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  dinosaurId Int?
  dinosaur   Dinosaur? @relation(fields: [dinosaurId], references: [id])

  image      String

  note       String   @db.Text

  location   String?

  createdAt  DateTime @default(now())
}

model QuizAttempt {
  id             Int      @id @default(autoincrement())

  userId         Int
  user           User     @relation(fields: [userId], references: [id])

  score          Int
  totalQuestions Int

  createdAt      DateTime @default(now())
}